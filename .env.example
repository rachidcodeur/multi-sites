# Configuration Supabase pour le formulaire de contact
# Copier ce fichier vers .env et remplir les valeurs

SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=eyJ...votre-cle-anon...
SUPABASE_TABLE=leads_peinture
SUPABASE_TABLE_INTERIEUR=leads_interieur

# Mode d'appel API :
#   0 = appel direct vers Supabase (nécessite CORS autorisé dans Supabase)
#   1 = même origine + proxy Nginx (nécessite bloc location /rest/v1/ dans Nginx)
SUPABASE_USE_RELATIVE_API=1

# Google Sheet — push automatique des villes déployées
# URL : Apps Script → Déployer → Application Web (URL générée)
# TOKEN : doit correspondre à SECRET_TOKEN dans google-apps-script.gs
DEPLOY_SHEET_URL=https://script.google.com/macros/s/.../exec
DEPLOY_SHEET_TOKEN=ton-token-secret

# Google Sheet pour le projet PEINTRE INTÉRIEUR (sheet séparé)
# https://docs.google.com/spreadsheets/d/107Y6cMygcKOjxx8S4DHxMSXJ34UJPtyUhA05dnw3v1k/
DEPLOY_SHEET_INTERIEUR_URL=https://script.google.com/macros/s/.../exec
DEPLOY_SHEET_INTERIEUR_TOKEN=ton-token-secret-interieur
